{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/drifter-thesis/launcher_matrix.schema.json",
  "title": "Drifter thesis launcher matrix",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "catalog_version",
    "entrypoint",
    "categories",
    "role_groups",
    "entries"
  ],
  "properties": {
    "catalog_version": {
      "type": "string",
      "minLength": 1
    },
    "entrypoint": {
      "const": "start.ps1"
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "category_id",
          "label",
          "description"
        ],
        "properties": {
          "category_id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "role_groups": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "menu_order",
          "GroupId",
          "MenuKey",
          "Label",
          "Description",
          "thesis_roles"
        ],
        "properties": {
          "menu_order": {
            "type": "number"
          },
          "GroupId": {
            "type": "string",
            "minLength": 1
          },
          "MenuKey": {
            "type": "string",
            "minLength": 1
          },
          "Label": {
            "type": "string",
            "minLength": 1
          },
          "Description": {
            "type": "string",
            "minLength": 1
          },
          "thesis_roles": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "primary_evidence",
                "support_context",
                "comparator_support",
                "archive_provenance",
                "legacy_support",
                "read_only_governance"
              ]
            }
          }
        }
      }
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "entry_id",
          "label",
          "category_id",
          "workflow_mode",
          "description",
          "rerun_cost",
          "safe_default",
          "thesis_role",
          "manuscript_section",
          "claim_boundary",
          "run_kind",
          "recommended_for",
          "confirms_before_run",
          "thesis_facing",
          "reportable",
          "experimental_only",
          "steps"
        ],
        "properties": {
          "entry_id": {
            "type": "string",
            "minLength": 1
          },
          "menu_order": {
            "type": "number"
          },
          "category_id": {
            "type": "string",
            "minLength": 1
          },
          "workflow_mode": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "service_profile": {
            "type": "string"
          },
          "rerun_cost": {
            "type": "string",
            "minLength": 1
          },
          "safe_default": {
            "type": "boolean"
          },
          "thesis_role": {
            "type": "string",
            "enum": [
              "primary_evidence",
              "support_context",
              "comparator_support",
              "archive_provenance",
              "legacy_support",
              "read_only_governance"
            ]
          },
          "manuscript_section": {
            "type": "string",
            "minLength": 1
          },
          "claim_boundary": {
            "type": "string",
            "minLength": 1
          },
          "run_kind": {
            "type": "string",
            "enum": [
              "read_only",
              "packaging_only",
              "scientific_rerun",
              "comparator_rerun",
              "archive_rerun"
            ]
          },
          "recommended_for": {
            "type": "string",
            "minLength": 1
          },
          "confirms_before_run": {
            "type": "boolean"
          },
          "alias_of": {
            "type": "string"
          },
          "menu_hidden": {
            "type": "boolean"
          },
          "thesis_facing": {
            "type": "boolean"
          },
          "reportable": {
            "type": "boolean"
          },
          "experimental_only": {
            "type": "boolean"
          },
          "archive_status": {
            "type": "string",
            "enum": [
              "archive_provenance",
              "legacy_support",
              "experimental_only",
              "repository_only_development"
            ]
          },
          "archive_registry_id": {
            "type": "string",
            "minLength": 1
          },
          "launcher_visibility": {
            "type": "string",
            "enum": [
              "visible_archive",
              "hidden_alias",
              "hidden_experimental",
              "read_only_only"
            ]
          },
          "default_panel_path": {
            "type": "boolean"
          },
          "intentional_full_evidence_support_bundle": {
            "type": "boolean"
          },
          "expected_output_dirs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "steps": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": true,
              "required": [
                "phase",
                "service",
                "description"
              ],
              "properties": {
                "phase": {
                  "type": "string",
                  "minLength": 1
                },
                "service": {
                  "type": "string",
                  "enum": [
                    "pipeline",
                    "gnome"
                  ]
                },
                "description": {
                  "type": "string",
                  "minLength": 1
                },
                "extra_env": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
