# Ingestion Credentials Template
# Copy this file to .env or export these variables in your shell before running ingestion

# Copernicus Marine Service (CMEMS)
# Register: https://data.marine.copernicus.eu/register
CMEMS_USERNAME=your_email@example.com
CMEMS_PASSWORD=your_password

# Climate Data Store (ERA5)
# Register: https://cds.climate.copernicus.eu/
CDS_URL=https://cds.climate.copernicus.eu/api
CDS_KEY=your_api_key
